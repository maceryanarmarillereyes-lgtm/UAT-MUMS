# ============================================================
# MUMS — Environment Variables Reference
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# Your project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe for client-side use)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Auth / Domain ───────────────────────────────────────────
# Email domain appended to usernames at login (e.g. mums.local)
USERNAME_EMAIL_DOMAIN=mums.local

# ── QuickBase Integration ───────────────────────────────────
# QuickBase realm hostname (e.g. mycompany.quickbase.com)
QB_REALM_HOSTNAME=your-realm.quickbase.com

# QuickBase user token (obtain from QB Account Settings)
QB_USER_TOKEN=your-quickbase-user-token

# QuickBase table IDs used by the integration
QB_TABLE_ID=your-quickbase-table-id

# ── Presence & Polling (Free Tier Optimised) ────────────────
# Heartbeat interval in ms (default: 45000 = 45s)
PRESENCE_POLL_MS=45000

# Presence roster poll interval in ms (default: 90000 = 90s)
PRESENCE_LIST_POLL_MS=90000

# Presence TTL in seconds — row stays "alive" between heartbeats
PRESENCE_TTL_SECONDS=360

# Mailbox status override poll interval in ms (default: 60000 = 60s)
MAILBOX_OVERRIDE_POLL_MS=60000

# Sync reconcile interval in ms (default: 90000 = 90s)
SYNC_RECONCILE_MS=90000

# ── Realtime Kill Switch ────────────────────────────────────
# Set to 'false' ONLY in a Disk IO emergency to disable Supabase Realtime.
# Leave unset or 'true' for normal operation.
SYNC_ENABLE_SUPABASE_REALTIME=true

# ── Realtime Relay ──────────────────────────────────────────
# Optional: URL of a self-hosted Supabase Realtime relay
REALTIME_RELAY_URL=

# ── Remote Patch ───────────────────────────────────────────
# Optional: URL for remote patch delivery endpoint
REMOTE_PATCH_URL=

# ── Controller Lab (Google Sheets Endpoint) ─────────────────
# Google Apps Script Web App URL for the Controller Lab logging sheet.
# Set this if you want to override the default hardcoded endpoint.
CTL_SHEETS_ENDPOINT=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec
