# =============================================================================
# NEWMACE Environment Variables
# Phase 637 | QBTabBugFix
# =============================================================================
# HOW THIS WORKS:
#   - Same codebase deploys to BOTH PROD and UAT.
#   - The ONLY thing that changes between environments is these env vars.
#   - Set these in your hosting platform (Cloudflare Pages or Vercel) dashboard.
#   - NEVER commit real values to git.
# =============================================================================

# ------------------------------------------------------------
# SUPABASE (Required)
# ------------------------------------------------------------
# PROD:  Use your Production Supabase project values
# UAT:   Use your UAT Supabase project values (separate project)

SUPABASE_URL=
SUPABASE_ANON_KEY=

# Supabase service role key — server-side only. NEVER expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_POOLER_URL=       # transaction pooler, port 6543

# ------------------------------------------------------------
# APP CONFIG (Required)
# ------------------------------------------------------------
# Username-to-email domain for CloudAuth login + user creation
# Example: meys.gov.ph | mums.local
USERNAME_EMAIL_DOMAIN=mums.local

# Bootstrap SUPER_ADMIN account (set on first deploy, optional after)
# SUPERADMIN_EMAIL=someone@mums.local
SUPERADMIN_EMAIL=

# ------------------------------------------------------------
# STORAGE (Profile photos)
# ------------------------------------------------------------
# Bucket must be PUBLIC in Supabase Storage dashboard.
SUPABASE_PUBLIC_BUCKET=public

# ------------------------------------------------------------
# REALTIME & SYNC
# FIX v3.9.30: Increased reconcile interval to 90s (was 15s).
# 15s caused excessive DB reads under 30-user free-tier load.
# ------------------------------------------------------------
SYNC_ENABLE_SUPABASE_REALTIME=true
SYNC_RECONCILE_MS=90000
SYNC_CONNECT_TIMEOUT_MS=7000
SYNC_PULL_RATE_PER_10S=1
SYNC_PUSH_RATE_PER_5S=1
AUTH_CACHE_TTL_MS=300000
CIRCUIT_BREAKER_THRESHOLD=5

# ------------------------------------------------------------
# PRESENCE
# FIX v3.9.30: Corrected presence intervals for free tier.
# PRESENCE_POLL_MS=3000 was dangerously low —
# 3s heartbeat × 30 users = 900 writes/min = IO budget destroyed.
# Correct values: heartbeat every 45s, roster list every 90s.
# ------------------------------------------------------------
PRESENCE_POLL_MS=45000
PRESENCE_LIST_POLL_MS=90000
PRESENCE_TTL_SECONDS=120

# ------------------------------------------------------------
# E2E / Playwright Tests
# ------------------------------------------------------------
# Store real values as GitHub Secrets. Never commit credentials.

# Deployed base URLs
CLOUDFLARE_URL=
VERCEL_URL=

# Supabase project ref validation (optional safety check in CI)
EXPECTED_PROD_REF=
EXPECTED_UAT_REF=

# Test users (separate accounts per environment)
PROD_USER_EMAIL=
PROD_USER_PASSWORD=
UAT_USER_EMAIL=
UAT_USER_PASSWORD=
