{
  "name": "SupportRecord",
  "type": "object",
  "properties": {
    "category_id": { "type": "string", "description": "Category identifier" },
    "category_name": { "type": "string", "description": "Display name of the category" },
    "title": { "type": "string", "description": "Title/subject of the support record" },
    "resolution": { "type": "string", "description": "Full resolution/response content" },
    "case_number": { "type": "string", "description": "QuickBase case number" },
    "end_user": { "type": "string", "description": "End user / customer name" },
    "source_tab": { "type": "string", "enum": ["quickbase", "knowledge_base", "contact_info", "parts_number", "product_controllers", "support_records"] },
    "icon": { "type": "string" },
    "color": { "type": "string" },
    "part_number": { "type": "string" },
    "description": { "type": "string" },
    "status": { "type": "string", "enum": ["open", "closed", "pending", "in_progress"] }
  },
  "required": ["title", "category_name"]
}
