{
  "name": "mums-realtime-green-mandatory",
  "private": true,
  "description": "MUMS static webapp + Vercel Serverless API routes (Supabase-backed)",
  "engines": {
    "node": "20.x"
  },
  "version": "1.0.0",
  "scripts": {
    "vercel-build": "echo \"Static site deployment \u2014 no build step required\"",
    "build": "npm run vercel-build",
    "start": "node -e \"console.log(\\\"Static site: no start script\\\")\"",
    "test:env": "node scripts/test-env.js",
    "test:login": "playwright test tests/login.spec.js",
    "package:phase1": "node tools/package_phase1_release.js",
    "qa:deploy": "bash scripts/qa-deploy.sh",
    "test:routes": "node scripts/validate_routes_json.js",
    "test": "npm run test:cf:unit && node tests/quickbaseSync.service.test.js && node tests/quickbaseSync.integration.test.js && node tests/supabase-overload.test.js",
    "test:cf:unit": "jest --config jest.config.cjs",
    "test:cf:e2e": "playwright test tests/e2e/services-conditional-format.spec.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "pg": "^8.13.1"
  }
}
